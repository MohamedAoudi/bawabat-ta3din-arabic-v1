# AMIP environment configuration.
# Real environment variables take precedence over this file; in production
# inject values at runtime (Docker --env-file / orchestrator secrets) and
# never bake them into the image.

# ── Runtime mode ──────────────────────────────────────────────────────────────
# "production" enforces: DB credentials set, CORS not "*", /docs disabled.
APP_ENV=development

# ── PostgreSQL connection (required) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amip_db
DB_USER=postgres
DB_PASSWORD=root
# Schema set as default search_path (now using simplified public schema)
DB_SCHEMA=public

# Connection pool (optional; defaults shown)
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Query limits (optional). statement_timeout = QUERY_TIMEOUT_SECONDS * 1000.
QUERY_TIMEOUT_SECONDS=10
MAX_RESULT_ROWS=500

# ── Data directory overrides (pipelines only, optional) ──────────────────────
RAW_DATA_DIR=data/raw
BILATERAL_DIR=data/raw/bilateral
PROCESSED_DIR=data/processed

# ── OpenAI (required) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o
# Per-call timeout and bounded retries (SDK exponential backoff on 429/5xx)
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3

# ── LightRAG (required for the RAG/concept mode) ──────────────────────────────
LIGHTRAG_BASE_URL=http://localhost:9622
LIGHTRAG_TIMEOUT=30
LIGHTRAG_MODE=hybrid

# ── Redis: sessions, SQL caches, rate-limit storage ───────────────────────────
# When unreachable the app degrades gracefully: in-memory sessions, no cache.
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6380/0
REDIS_SESSION_TTL_SECONDS=3600
REDIS_SESSION_PREFIX=amip:session:
SQL_CACHE_ENABLED=true
SQL_CACHE_TTL_SECONDS=86400
SQL_CACHE_PREFIX=amip:sql_cache:

# ── Per-IP rate limiting (protects the OpenAI budget) ─────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=0
RATE_LIMIT_PER_DAY=500
# Defaults to REDIS_URL when unset
#RATE_LIMIT_STORAGE_URL=

# ── Conversation behavior (optional) ──────────────────────────────────────────
CLARIFICATION_THRESHOLD=0.75
CACHE_EVICTION_THRESHOLD=5
MAX_HISTORY_TURNS=20
CONTEXT_REWRITE_ENABLED=true
CONTEXT_REWRITE_MAX_CHARS=120

# ── HTTP server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Gunicorn (Docker) tuning
#GUNICORN_WORKERS=4
#GUNICORN_BIND=0.0.0.0:8000
#GUNICORN_TIMEOUT=120

# ── CORS — set to the real frontend origin(s) in production, never "*" ───────
CORS_ALLOWED_ORIGINS=*

# ── Eval log (JSONL of chat turns; defaults outside the repo) ─────────────────
#EVAL_LOG_PATH=/var/log/amip/eval.jsonl
